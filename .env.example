# Copy this file to .env.local and fill in local secrets.
# .env.local is ignored by git and must never be committed.

# Required only when you want to provide the screenshot-analysis key via env.
# For public/static builds, prefer leaving this empty and entering the key in
# the app settings instead, because VITE_* values are exposed to the browser.
GEMINI_API_KEY=""
VITE_GEMINI_API_KEY=""

# Optional canonical app URL for deployment notes/integrations.
APP_URL=""
